# =============================================================================
# .gitignore — DevOps CI/CD Learning Laboratory
# =============================================================================

# =============================================================================
# Operating System
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
Icon

# Windows
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
[Dd]esktop.ini
$RECYCLE.BIN/
*.stackdump
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# IDE and Editors
# =============================================================================

# JetBrains (IntelliJ, GoLand, etc.)
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code
.vscode/
*.code-workspace

# Eclipse
.classpath
.project
.settings/
bin/

# NetBeans
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# Vim / Emacs
*.swp
*.swo
*~
.metadata/

# Sublime Text
*.sublime-project
*.sublime-workspace

# =============================================================================
# Java / Maven (Backend)
# =============================================================================

target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# =============================================================================
# Node.js / Frontend (React + Vite)
# =============================================================================

node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.*.local
.npm
.eslintcache
.node_repl_history
.yarn-integrity
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Lock files — keep package-lock.json for reproducible CI/CD builds
yarn.lock

# =============================================================================
# Docker
# =============================================================================

# Note: .dockerignore files should be tracked in git — do NOT add them here

# =============================================================================
# Kubernetes
# =============================================================================

*.kubeconfig
kubeconfig
.kube/

# =============================================================================
# Harbor Container Registry
# =============================================================================

harbor/data/
harbor/logs/
harbor/common/config/
harbor/harbor.yml
harbor/prepare

# =============================================================================
# Jenkins
# =============================================================================

.jenkins/
jenkins_home/
jenkins-pipeline.log

# =============================================================================
# SonarQube
# =============================================================================

.sonar/
.scannerwork/

# =============================================================================
# ArgoCD
# =============================================================================

argocd-secret.yaml

# =============================================================================
# Helm
# =============================================================================

charts/*/charts/
charts/*/tmpcharts/

# =============================================================================
# Terraform
# =============================================================================

*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# =============================================================================
# Ansible
# =============================================================================

*.retry
.vault_pass
.vault_pass.txt
vault_pass

# =============================================================================
# Secrets, Credentials and Certificates
# =============================================================================

# Environment files (.env.template is intentionally NOT ignored)
.env
.env.local
.env.*.local

# Generic secret patterns
secrets.yml
secrets.yaml
*secret*
*password*
*credentials*

# Certificates and keys
*.pem
*.key
*.cer
*.crt
*.der
*.p7b
*.p7c
*.p12
*.pfx
*.keystore
*.jks
*.truststore

# SSH keys
id_rsa
id_rsa.pub
id_dsa
id_dsa.pub
id_ecdsa
id_ecdsa.pub
id_ed25519
id_ed25519.pub
known_hosts

# Cloud provider credentials
.aws/

# =============================================================================
# Logs and Runtime Data
# =============================================================================

logs/
*.log
error.log
pids/
*.pid
*.seed
*.pid.lock

# =============================================================================
# Test Results and Coverage Reports
# =============================================================================

coverage/
*.cover
htmlcov/
.coverage
.coverage.*
.hypothesis/
.pytest_cache/
.tox/
nosetests.xml
test-results/
junit.xml

# =============================================================================
# Temporary and Cache Files
# =============================================================================

tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
.cache/
.venv
venv/

# =============================================================================
# Archives and Compressed Files
# =============================================================================

*.7z
*.dmg
*.gz
*.iso
*.rar
*.tar
*.tar.gz
*.tgz
*.zip
*.war
*.ear
*.jar
*.deb
*.rpm
*.pkg

# =============================================================================
# CI/CD
# =============================================================================

.gitlab-ci-local/

# =============================================================================
# Local Configuration Overrides
# =============================================================================

local.properties
config.local.yml

# =============================================================================
# Project-specific Exceptions
# =============================================================================

# Allow Flyway migration SQL files (excluded by *.sql-like patterns elsewhere)
!src/main/resources/db/migration/*.sql

# Allow Helm chart archives in specific locations if needed
# !helm-charts/**/*.tgz
